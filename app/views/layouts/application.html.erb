<%# app/views/layouts/application.html.erb — Template HTML principal partagé par toutes les vues %>
<%# Contient la structure HTML de base : head, navbar, messages flash, footer %>
<!DOCTYPE html>
<html lang="fr">
  <head>
    <%# Encodage UTF-8 pour supporter les caractères accentués %>
    <meta charset="UTF-8">

    <%# Viewport responsive : adapte l'affichage aux mobiles et tablettes %>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <%# Titre de la page — défini par chaque vue grâce au helper content_for %>
    <title><%= content_for?(:title) ? yield(:title) + " | EventFreeka" : "EventFreeka" %></title>

    <%# Tags CSRF pour la sécurité des formulaires (protection contre les attaques) %>
    <%= csrf_meta_tags %>

    <%# Tags pour la gestion des types de contenu %>
    <%= csp_meta_tag %>

    <%# Charge les feuilles de style (Bootstrap + styles custom) %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <%# Charge les scripts JavaScript (Turbo, Stimulus, Stripe.js) %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%# ===== NAVIGATION ===== %>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <%# Logo / nom de l'application — lien vers la page d'accueil %>
        <%= link_to "🎉 EventFreeka", root_path, class: "navbar-brand fw-bold" %>

        <%# Bouton hamburger pour les petits écrans (Bootstrap) %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>

        <%# Liens de navigation %>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <%# Lien vers la liste des événements %>
            <li class="nav-item">
              <%= link_to "Événements", events_path, class: "nav-link" %>
            </li>

            <%# Affiche les liens de connexion/déconnexion selon l'état de l'utilisateur %>
            <% if user_signed_in? %>
              <%# Affiche l'email de l'utilisateur connecté %>
              <li class="nav-item">
                <span class="nav-link text-light opacity-75"><%= current_user.email %></span>
              </li>

              <%# Lien pour créer un nouvel événement (utilisateur connecté uniquement) %>
              <li class="nav-item">
                <%= link_to "Créer un événement", new_event_path, class: "nav-link" %>
              </li>

              <%# Lien de déconnexion Devise %>
              <li class="nav-item">
                <%= link_to "Déconnexion", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link" %>
              </li>
            <% else %>
              <%# Lien de connexion pour les visiteurs non connectés %>
              <li class="nav-item">
                <%= link_to "Connexion", new_user_session_path, class: "nav-link" %>
              </li>

              <%# Lien d'inscription %>
              <li class="nav-item">
                <%= link_to "Inscription", new_user_registration_path, class: "btn btn-outline-light ms-2" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <%# ===== MESSAGES FLASH ===== %>
    <%# Affiche les notifications de succès/erreur après chaque action %>
    <div class="container mt-3">
      <% if notice %>
        <%# Message de succès — fond vert %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <%= notice %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <% if alert %>
        <%# Message d'erreur — fond rouge %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <%= alert %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>
    </div>

    <%# ===== CONTENU PRINCIPAL ===== %>
    <%# yield insère ici le contenu spécifique à chaque vue %>
    <main class="container my-4">
      <%= yield %>
    </main>

    <%# ===== FOOTER ===== %>
    <footer class="bg-dark text-light text-center py-3 mt-5">
      <p class="mb-0">EventFreeka &copy; <%= Date.current.year %> — Propulsé par Rails &amp; Stripe</p>
    </footer>
  </body>
</html>
